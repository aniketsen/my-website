---
/**
 * src/pages/index.astro
 * Home = one full-page pulsing-code wall behind everything, with the hero and
 * all the template sections sitting on top of it transparently.
 *
 * Layering (no negative z-index this time):
 *   .page-wall  -> fixed, z-index 0, carries the canvas colour + the code
 *   .code-hero  -> z-index 1, transparent (code shows behind it)
 *   .home-content (sections) -> z-index 1, transparent (code shows behind it)
 *   footer      -> made transparent on this page so code shows behind it too
 *
 * Light/dark via CSS variables keyed off the theme's `.dark` class.
 * Scoped to the home page with `:has(.code-hero)` so other pages are untouched.
 */
import { getCollection } from "astro:content"
import PageLayout from "@layouts/PageLayout.astro"
import PulsingCode from "@components/PulsingCode.astro"
import ArrowCard from "@components/ArrowCard"
import StackCard from "@components/StackCard.astro"
import { SITE, SOCIALS } from "@consts"

const posts = (await getCollection("blog"))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3)

const projects = (await getCollection("projects"))
  .filter(project => !project.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3)

// "Website built with" — these icon names ship with the theme.
const stack = [
  { text: "Astro", icon: "astro", href: "https://astro.build" },
  { text: "Javascript", icon: "javascript", href: "https://www.javascript.com" },
  { text: "Typescript", icon: "typescript", href: "https://www.typescriptlang.org" },
  { text: "Tailwind", icon: "tailwind", href: "https://tailwindcss.com" },
]
---

<PageLayout title="Home" description={SITE.DESCRIPTION}>

  <!-- one code wall behind the whole page -->
  <div class="page-wall"><PulsingCode /></div>

  <!-- HERO -->
  <section class="code-hero">
    <div class="ch-inner">
      <p class="ch-eyebrow">HPC <span class="ch-tick">·</span> Lattice QCD <span class="ch-tick">·</span> Research Software Engineering</p>
      <h1 class="ch-name">Aniket Sen<span class="ch-caret">&nbsp;</span></h1>
      <p class="ch-tagline">
        I put quantum fields on a <span class="ch-k">lattice</span> — and write the
        <span class="ch-k">high-performance</span> code that makes them run.
      </p>
      <div class="ch-actions">
        <a class="ch-btn ch-btn-solid" href="/blog">Read the blog</a>
        <a class="ch-btn ch-btn-ghost" href="/projects">Browse the code <span class="ch-arrow">↗</span></a>
      </div>
    </div>
  </section>

  <!-- CONTENT sections (transparent, code shows behind them) -->
  <div class="home-content">
    <div class="mx-auto max-w-screen-sm p-5 space-y-24 pb-16">

      <!-- About Section  (edit this to taste) -->
      <section class="animate">
        <article>
          <p>I'm a postdoctoral researcher in <b>lattice QCD</b> at the Helmholtz-Institut für Strahlen- und Kernphysik (HISKP), University of Bonn, working within the Extended Twisted Mass Collaboration.</p>
          <p>My work sits on the boundary between theoretical physics and high-performance computing: putting quantum field theories on a discretised spacetime lattice, and building the parallel code that makes those calculations tractable on supercomputers.</p>
          <p>Alongside the physics, I work as a <b>research software engineer</b> — contributing to open-source lattice field theory libraries and developing performance-portable code with Kokkos.</p>
        </article>
      </section>

      <!-- Blog Preview Section -->
      <section class="animate">
        <div class="space-y-4">
          <div class="flex justify-between">
            <p class="font-semibold text-black dark:text-white">
              Recent posts
            </p>
            <a href="/blog" class="w-fit col-span-3 group flex gap-1 items-center underline decoration-[.5px] decoration-black/25 dark:decoration-white/50 hover:decoration-black dark:hover:decoration-white text-black dark:text-white underline-offset-2 blend">
              <span class="text-black/75 dark:text-white/75 group-hover:text-black group-hover:dark:text-white blend">
                All posts
              </span>
            </a>
          </div>
          <ul class="space-y-4">
            {posts.map((post) => (
              <li>
                <ArrowCard entry={post} />
              </li>
            ))}
          </ul>
        </div>
      </section>

      <!-- Tech Stack Section -->
      <section class="animate">
        <div class="space-y-4">
          <p class="font-semibold text-black dark:text-white">
            Website built with
          </p>
          <div class="flex flex-wrap items-center gap-2 mt-5">
            {stack.map(item => (
              <StackCard
                text={item.text}
                icon={item.icon}
                href={item.href}
              />
            ))}
          </div>
          <div>
            Performing reactivity and statefulness, special guest
            <a href="https://www.solidjs.com/" target="_blank" class="w-fit group underline decoration-[.5px] decoration-black/25 dark:decoration-white/50 hover:decoration-black dark:hover:decoration-white text-black dark:text-white underline-offset-2 blend">
              <span class="text-black/75 dark:text-white/75 group-hover:text-black group-hover:dark:text-white blend">
                SolidJS
              </span>
            </a>
          </div>
        </div>
      </section>

      <!-- Project Preview Section -->
      <section class="animate">
        <div class="space-y-4">
          <div class="flex justify-between">
            <p class="font-semibold text-black dark:text-white">
              Recent projects
            </p>
            <a href="/projects" class="w-fit col-span-3 group flex gap-1 items-center underline decoration-[.5px] decoration-black/25 dark:decoration-white/50 hover:decoration-black dark:hover:decoration-white text-black dark:text-white underline-offset-2 blend">
              <span class="text-black/75 dark:text-white/75 group-hover:text-black group-hover:dark:text-white blend">
                All projects
              </span>
            </a>
          </div>
          <ul class="space-y-4">
            {projects.map((project) => (
              <li>
                <ArrowCard entry={project} />
              </li>
            ))}
          </ul>
        </div>
      </section>

      <!-- Contact Section -->
      <section class="animate">
        <div>
          <p class="font-semibold text-black dark:text-white">
            Let's Connect
          </p>
          <p>
            Reach out to me via email or on social media.
          </p>
          <div class="grid grid-cols-4 gap-y-2 mt-4 auto-cols-min">
            {SOCIALS.map(social => (
              <div class="col-span-1 flex items-center gap-1">
                <span class="whitespace-nowrap truncate">
                  {social.NAME}
                </span>
              </div>
              <div class="col-span-3 truncate">
                <a href={social.HREF} target="_blank" class="w-fit col-span-3 group flex gap-1 items-center underline decoration-[.5px] decoration-black/25 dark:decoration-white/50 hover:decoration-black dark:hover:decoration-white text-black dark:text-white underline-offset-2 blend">
                  <span class="text-black/75 dark:text-white/75 group-hover:text-black group-hover:dark:text-white blend">
                    {social.TEXT}
                  </span>
                </a>
              </div>
            ))}
          </div>
        </div>
      </section>

    </div>
  </div>

</PageLayout>

<style is:global>
  /* ---- home-page palette: light is the base, dark overrides ---- */
  body:has(.code-hero) {
    --canvas:         #ffffff;
    --pool:           rgba(255, 255, 255, 0.92);
    --name:           #0b1220;
    --eyebrow:        #475569;
    --tagline:        #334155;
    --accent:         #2563eb;
    --solid-bg:       #0b1220;
    --solid-fg:       #f8fafc;
    --ghost-fg:       #1e293b;
    --ghost-bd:       rgba(30, 41, 59, 0.25);
    --ghost-hover:    rgba(37, 99, 235, 0.08);
  }
  html.dark body:has(.code-hero) {
    --canvas:         #000000;
    --pool:           rgba(0, 0, 0, 0.92);
    --name:           #f4f7fc;
    --eyebrow:        #93a4bf;
    --tagline:        #aeb9cc;
    --accent:         #79c8ff;
    --solid-bg:       #eef3fb;
    --solid-fg:       #0b0e14;
    --ghost-fg:       #dce4f1;
    --ghost-bd:       rgba(160, 190, 230, 0.28);
    --ghost-hover:    rgba(121, 200, 255, 0.08);
  }

  /* the wall: one fixed layer behind everything, carrying the canvas colour */
  .page-wall {
    position: fixed;
    inset: 0;
    z-index: 0;
    background: var(--canvas);
    pointer-events: none;
  }

  /* let the code show behind the footer too (home page only) */
  body:has(.code-hero) footer { background-color: transparent; }

  /* ---- HERO (sits above the wall, transparent) ---- */
  .code-hero {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 1.5rem;
  }
  /* soft pool of the canvas colour behind the hero text for legibility */
  .code-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background: radial-gradient(46% 42% at 50% 50%,
      var(--pool) 0%, color-mix(in srgb, var(--pool) 60%, transparent) 45%, transparent 75%);
  }
  .ch-inner { position: relative; z-index: 1; }

  /* ---- CONTENT sections (above the wall, transparent) ---- */
  .home-content { position: relative; z-index: 1; }

  .ch-eyebrow {
    font-family: ui-monospace, "JetBrains Mono", "Fira Code", SFMono-Regular, Menlo, monospace;
    font-size: clamp(11px, 1.4vw, 13px);
    letter-spacing: 0.34em;
    text-transform: uppercase;
    color: var(--eyebrow);
    margin-bottom: 1.1rem;
  }
  .ch-eyebrow .ch-tick { color: var(--accent); }

  .ch-name {
    font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
    font-weight: 800;
    font-size: clamp(2.6rem, 8vw, 5.6rem);
    line-height: 0.98;
    letter-spacing: -0.02em;
    color: var(--name);
    margin: 0;
  }

  .ch-tagline {
    margin: 1.3rem auto 0;
    max-width: 40ch;
    font-size: clamp(0.98rem, 2.1vw, 1.18rem);
    line-height: 1.5;
    color: var(--tagline);
  }
  .ch-tagline .ch-k { color: var(--accent); font-weight: 600; }

  .ch-actions {
    margin-top: 2.1rem;
    display: flex;
    gap: 0.7rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  .ch-btn {
    font-family: ui-monospace, "JetBrains Mono", SFMono-Regular, Menlo, monospace;
    font-size: 0.84rem;
    letter-spacing: 0.02em;
    padding: 0.62rem 1.1rem;
    border-radius: 7px;
    text-decoration: none;
    transition: transform .15s ease, background .2s ease, border-color .2s ease;
  }
  .ch-btn:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; }
  .ch-btn-solid { background: var(--solid-bg); color: var(--solid-fg); }
  .ch-btn-solid:hover { transform: translateY(-1px); filter: brightness(1.05); }
  .ch-btn-ghost { color: var(--ghost-fg); border: 1px solid var(--ghost-bd); }
  .ch-btn-ghost:hover { transform: translateY(-1px); border-color: var(--accent); background: var(--ghost-hover); }
  .ch-btn .ch-arrow { color: var(--accent); }

  .ch-caret {
    display: inline-block;
    width: 0.6ch;
    margin-left: 0.1ch;
    background: var(--accent);
    animation: ch-blink 1.1s steps(1) infinite;
  }
  @keyframes ch-blink { 0%, 50% { opacity: 1; } 50.01%, 100% { opacity: 0; } }

  @media (prefers-reduced-motion: reduce) {
    .ch-caret { animation: none; }
  }
</style>